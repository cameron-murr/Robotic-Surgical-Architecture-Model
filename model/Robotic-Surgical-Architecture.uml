  <Blocks:NestedConnectorEnd xmi:id="_BNI6IHNFEfGImPMr3c7uaQ" base_Element="_BNITEHNFEfGImPMr3c7uaQ" propertyPath="_SDQ_MHNEEfGImPMr3c7uaQ" base_ConnectorEnd="_BNITEHNFEfGImPMr3c7uaQ"/>
  <Blocks:NestedConnectorEnd xmi:id="_BNJhMHNFEfGImPMr3c7uaQ" base_Element="_BNITEXNFEfGImPMr3c7uaQ" propertyPath="_SDXF2HNEEfGImPMr3c7uaQ" base_ConnectorEnd="_BNITEXNFEfGImPMr3c7uaQ"/>
  <Blocks:NestedConnectorEnd xmi:id="_B_XBQHNFEfGImPMr3c7uaQ" base_Element="_B_WaMHNFEfGImPMr3c7uaQ" propertyPath="_SDQ_MHNEEfGImPMr3c7uaQ" base_ConnectorEnd="_B_WaMHNFEfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="__WtzsHP3EfGImPMr3c7uaQ" base_NamedElement="__WqJUHP3EfGImPMr3c7uaQ" id="UN-001" text="Physicians need to navigate a bronchoscope to a target nodule identified in preoperative imaging in order to obtain a tissue biopsy." base_Class="__WqJUHP3EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_0riYgHP5EfGImPMr3c7uaQ" base_NamedElement="_0racsHP5EfGImPMr3c7uaQ" id="UN-002" text="Physicians need to reach target nodules located in peripheral airway branches that are difficult or impossible to access with manual bronchoscopy." base_Class="_0racsHP5EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_1A918HP5EfGImPMr3c7uaQ" base_NamedElement="_1A5kgHP5EfGImPMr3c7uaQ" id="UN-003" text="Patients need assurance that navigation will not cause unintended injury to the airway." base_Class="_1A5kgHP5EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_1SCX0HP5EfGImPMr3c7uaQ" base_NamedElement="_1R-GYHP5EfGImPMr3c7uaQ" id="UN-004" text="Physicians need to retain supervisory authority over the procedure, including the ability to pause or abort navigation at any time." base_Class="_1R-GYHP5EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_1rzisHP5EfGImPMr3c7uaQ" base_NamedElement="_1rvRQHP5EfGImPMr3c7uaQ" id="UN-005" text="Clinical staff need a record of the navigation procedure to support post-procedure review." base_Class="_1rvRQHP5EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_bp8G0HP6EfGImPMr3c7uaQ" base_NamedElement="_bpy84HP6EfGImPMr3c7uaQ" id="SYS-REQ-001" text="The system shall enable a physician to navigate a flexible bronchoscope to target pulmonary nodules identified in preoperative imaging." base_Class="_bpy84HP6EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_b-jr8HP6EfGImPMr3c7uaQ" base_NamedElement="_b-ezcHP6EfGImPMr3c7uaQ" id="SYS-REQ-002" text="The system shall provide the physician with sufficient positional confidence to perform a tissue biopsy at the target location." base_Class="_b-ezcHP6EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_fZsWEHP6EfGImPMr3c7uaQ" base_NamedElement="_fZm2gHP6EfGImPMr3c7uaQ" id="SYS-REQ-003" text="The system shall prevent unintended scope advancement or steering that could result in airway wall injury." base_Class="_fZm2gHP6EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_gURvAHP6EfGImPMr3c7uaQ" base_NamedElement="_gUMPcHP6EfGImPMr3c7uaQ" id="SYS-REQ-004" text="The system shall respond to physician pause and abort commands within a clinically acceptable time." base_Class="_gUMPcHP6EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_g5lbgHP6EfGImPMr3c7uaQ" base_NamedElement="_g5f78HP6EfGImPMr3c7uaQ" id="SYS-REQ-005" text="The system shall generate a complete procedure record suitable for post-procedure clinical review." base_Class="_g5f78HP6EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_hi9vsHP6EfGImPMr3c7uaQ" base_NamedElement="_hi43MHP6EfGImPMr3c7uaQ" id="SYS-REQ-006" text="The system shall detect conditions under which navigation accuracy cannot be assured and shall prevent scope motion under those conditions." base_Class="_hi43MHP6EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_pcNR8HP8EfGImPMr3c7uaQ" base_NamedElement="_pb-BYHP8EfGImPMr3c7uaQ" id="SUB-REQ-001" text="The RBNS shall produce a fused bronchoscope tip pose estimate at a rate of no less than 30 Hz during the NAVIGATE phase." base_Class="_pb-BYHP8EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_sFFYsHP8EfGImPMr3c7uaQ" base_NamedElement="_sE_SEHP8EfGImPMr3c7uaQ" id="SUB-REQ-002" text="Each fused tip pose estimate shall include a 3D position uncertainty representation expressed as an ellipsoid with semi-axis lengths in millimeters." base_Class="_sE_SEHP8EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_tME18HP8EfGImPMr3c7uaQ" base_NamedElement="_tL_WYHP8EfGImPMr3c7uaQ" id="SUB-REQ-003" text="The RBNS shall complete image-to-patient registration within 4 seconds of receiving a Cone Beam Computed Tomography (CBCT) volume." base_Class="_tL_WYHP8EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_vcMecHP8EfGImPMr3c7uaQ" base_NamedElement="_vcG-4HP8EfGImPMr3c7uaQ" id="SUB-REQ-004" text="The RBNS shall inhibit path replanning when the tip position uncertainty exceeds the configured replanning threshold." base_Class="_vcG-4HP8EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_wVXiIHP8EfGImPMr3c7uaQ" base_NamedElement="_wVSCkHP8EfGImPMr3c7uaQ" id="SUB-REQ-005" text="The replanning uncertainty threshold shall be a configurable parameter modifiable without software rebuild." base_Class="_wVSCkHP8EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_MeVX8HP9EfGImPMr3c7uaQ" base_NamedElement="_MeNcIHP9EfGImPMr3c7uaQ" id="SUB-REQ-006" text="The RBNS shall command zero scope advancement (HOLD) within one guidance cycle of the tip position uncertainty exceeding the configured threshold." base_Class="_MeNcIHP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_QsXeoHP9EfGImPMr3c7uaQ" base_NamedElement="_QsR_EHP9EfGImPMr3c7uaQ" id="SUB-REQ-007" text="All guidance commands shall be magnitude-limited to configurable maximum advance rate and maximum steering angle values prior to transmission on IF-07." base_Class="_QsR_EHP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_Rb7TUHP9EfGImPMr3c7uaQ" base_NamedElement="_Rb2a0HP9EfGImPMr3c7uaQ" id="SUB-REQ-008" text="The RBNS shall implement the procedure state machine with states IDLE, NAVIGATE, CONFIRM, BIOPSY, FAULT, and ABORT, with transitions as defined in the Supervisor state machine model." base_Class="_Rb2a0HP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_SKx9YHP9EfGImPMr3c7uaQ" base_NamedElement="_SKozcHP9EfGImPMr3c7uaQ" id="SUB-REQ-009" text="All command, control, status, and logging communication between the RBNS and external systems shall be routed through the Procedure Supervisor, with the exception of continuous sensor and imaging feeds (IF-EX-02a, IF-EX-03, IF-EX-08), which connect directly to their consuming subsystem." base_Class="_SKozcHP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_Tb94cHP9EfGImPMr3c7uaQ" base_NamedElement="_Tb4Y4HP9EfGImPMr3c7uaQ" id="SUB-REQ-010" text="The RBNS shall report a lost-tracking alert to the Procedure Supervisor within 100 ms of tracking loss detection." base_Class="_Tb4Y4HP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_WBV_QHP9EfGImPMr3c7uaQ" base_NamedElement="_WBRGwHP9EfGImPMr3c7uaQ" id="SUB-REQ-011" text="Upon deassertion of the motion enable signal (IF-EX-06a), the RBNS shall cease issuing guidance commands within 50 ms." base_Class="_WBRGwHP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_W1dj0HP9EfGImPMr3c7uaQ" base_NamedElement="_W1YEQHP9EfGImPMr3c7uaQ" id="SUB-REQ-012" text="Upon receiving a lost-tracking alert, the Procedure Supervisor shall transition to the FAULT state and command HOLD on IF-EX-04 within 100 ms." base_Class="_W1YEQHP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_Xu9XoHP9EfGImPMr3c7uaQ" base_NamedElement="_Xu34EHP9EfGImPMr3c7uaQ" id="SUB-REQ-013" text="The RBNS shall maintain a degraded tip pose estimate upon failure of any single localization source, and shall flag the estimate as DEGRADED on IF-03." base_Class="_Xu34EHP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_YfYH8HP9EfGImPMr3c7uaQ" base_NamedElement="_YfT2gHP9EfGImPMr3c7uaQ" id="SUB-REQ-014" text="The RBNS shall compute an airway path from current position to a newly commanded target within 1 second." base_Class="_YfT2gHP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_aNZI8HP9EfGImPMr3c7uaQ" base_NamedElement="_aNUQcHP9EfGImPMr3c7uaQ" id="SUB-REQ-015" text="The end-to-end latency from a tip pose estimate (IF-01) to the corresponding guidance command transmission (IF-EX-04) shall not exceed 200 ms." base_Class="_aNUQcHP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_bAXeAHP9EfGImPMr3c7uaQ" base_NamedElement="_bAR-cHP9EfGImPMr3c7uaQ" id="SUB-REQ-016" text="The RBNS shall issue CBCT acquisition triggers (IF-EX-02b) only during the NAVIGATE and CONFIRM procedure phases." base_Class="_bAR-cHP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_b4WO4HP9EfGImPMr3c7uaQ" base_NamedElement="_b4RWYHP9EfGImPMr3c7uaQ" id="SUB-REQ-017" text="The RBNS shall record all state transitions, replanning events, fault events, and the tip pose trace to the Procedure Data Recorder (IF-EX-07) with timestamps of 10 ms resolution or better." base_Class="_b4RWYHP9EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_6se1AHP-EfGImPMr3c7uaQ" base_NamedElement="_6sZ8gHP-EfGImPMr3c7uaQ" id="COMP-REQ-001" text="The Guidance Command Generator shall support distal tip articulation commands of up to [TBD] degrees per axis, sufficient to follow airway centerline curvature at branch points up to the generation depth required by SYS-REQ-001." base_Class="_6sZ8gHP-EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_7DnioHP-EfGImPMr3c7uaQ" base_NamedElement="_7DiqIHP-EfGImPMr3c7uaQ" id="COMP-REQ-002" text="The Sensor Fusion &amp; Uncertainty Estimator shall bound the fused position uncertainty ellipsoid such that the 95% confidence volume does not exceed [TBD]." base_Class="_7DiqIHP-EfGImPMr3c7uaQ"/>
  <Requirements:Requirement xmi:id="_7X2tQHP-EfGImPMr3c7uaQ" base_NamedElement="_7Xx0wHP-EfGImPMr3c7uaQ" id="COMP-REQ-003" text="The Real-Time Path Updater shall default the replanning inhibition threshold to an uncertainty ellipsoid semi-axis of [TBD], configurable per SUB-REQ-005." base_Class="_7Xx0wHP-EfGImPMr3c7uaQ"/>
  <Requirements:Satisfy xmi:id="_fDTyMHQBEfGImPMr3c7uaQ" base_DirectedRelationship="_fDO5sHQBEfGImPMr3c7uaQ" base_Abstraction="_fDO5sHQBEfGImPMr3c7uaQ"/>
