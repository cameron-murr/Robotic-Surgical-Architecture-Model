    <!-- Design Decision Callout -->
    <mxCell id="dd_box" value="&lt;b&gt;Key Design Decision: Sensor Fusion Hierarchy&lt;/b&gt;&lt;br&gt;CBCT registration is periodic (triggered, ~low rate) and high-accuracy.&lt;br&gt;FK is continuous (high rate) but accumulates error under flexion.&lt;br&gt;Vision is medium rate, fails in low-contrast environments.&lt;br&gt;The EKF weights these three sources by their respective error covariances,&lt;br&gt;using CBCT registration as a periodic ground-truth correction to the continuous FK+vision estimate.&lt;br&gt;This architecture tolerates any single-source failure gracefully." style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;fontSize=9;whiteSpace=wrap;rounded=1;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="700" y="200" width="580" height="120" as="geometry" />
    </mxCell>

    <!-- Uncertainty callout -->
